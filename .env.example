# Copy to .env.local and fill in real values. .env.local is gitignored.

# Supabase — service role key (secret! bypasses RLS, server-only)
# Get from: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# UUID of the Supabase auth user that will own bulk-imported ideas
# Get from: Supabase dashboard → Authentication → Users → your row → copy id
IMPORT_USER_ID=

# Anthropic API key (for /api/extract-* serverless functions, Phase 2)
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Shared secret used to authorize /api/admin-import-projects calls.
# Must match the password entered at /admin.html before hitting the endpoint.
ADMIN_SECRET=

# Resend API key — for transactional email (sunday sign-up confirmations,
# 7-day + 24h reminders, cancellation alerts).
# Get from: https://resend.com → API Keys → Create
# Free tier: 3,000 emails/month. From-address can be `onboarding@resend.dev`
# without DNS setup, or your own verified domain.
RESEND_API_KEY=

# Random secret used to authenticate Vercel cron requests against
# /api/cron-reminders. Generate any random string. Set on Vercel env
# (Production scope) so the cron headers match what the endpoint expects.
# If missing in production, the cron endpoint runs without auth — fine
# for solo dev, risky for live (anyone could trigger the cron).
CRON_SECRET=

