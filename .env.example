# Copy to .env.local and fill in real values. .env.local is gitignored.

# Supabase — service role key (secret! bypasses RLS, server-only)
# Get from: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# UUID of the Supabase auth user that will own bulk-imported ideas
# Get from: Supabase dashboard → Authentication → Users → your row → copy id
IMPORT_USER_ID=

# Anthropic API key (for /api/extract-* serverless functions, Phase 2)
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Shared secret used to authorize /api/admin-import-projects calls.
# Must match the password entered at /admin.html before hitting the endpoint.
ADMIN_SECRET=

